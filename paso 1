import requests
from bs4 import BeautifulSoup
import os
from supabase import create_client

# Configuración de las "llaves" (GitHub las tomará de los Secrets)
url_supabase = os.environ.get("SUPABASE_URL")
key_supabase = os.environ.get("SUPABASE_KEY")
supabase = create_client(url_supabase, key_supabase)

def buscar_y_guardar():
    print("🔎 Buscando voluntariados en Proa.pe...")
    url = "https://proa.pe/programas_todos"
    response = requests.get(url, headers={'User-Agent': 'Mozilla/5.0'})
    soup = BeautifulSoup(response.text, 'html.parser')
    
    # Buscamos los títulos de los voluntariados
    oportunidades = soup.find_all('h5')
    
    for op in oportunidades:
        titulo = op.get_text().strip()
        
        # Intentamos guardar en la tabla que me mostraste en la foto
        if len(titulo) > 5:
            datos = {
                "título": titulo,
                "entidad": "Proa.pe",
                "categoría": "Voluntariado"
            }
            # Esto envía el dato a la fila de tu imagen
            try:
                supabase.table("oportunidades").insert(datos).execute()
                print(f"✅ Guardado: {titulo}")
            except Exception as e:
                print(f"❌ Error al guardar {titulo}: {e}")

if __name__ == "__main__":
    buscar_y_guardar()
